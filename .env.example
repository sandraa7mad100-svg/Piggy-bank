# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The app runs fine with everything left blank: Firebase calls fall back to
# an offline/local mode and the AI assistant falls back to a local
# rule-based "mock" provider so the chat screen is always demoable.

# --- AI Assistant -----------------------------------------------------
# One of: mock | openai | gemini | claude
AI_PROVIDER=mock
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# --- Backend ------------------------------------------------------------
API_BASE_URL=https://api.example.com

# --- Firebase -------------------------------------------------------------
# Firebase itself is configured via `firebase_options.dart`
# (generated by `flutterfire configure`), not via .env. This flag only
# controls whether the app points at local emulators during development.
USE_FIREBASE_EMULATOR=false
